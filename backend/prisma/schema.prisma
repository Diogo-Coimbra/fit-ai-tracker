// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String       @id @default(uuid())
  googleId   String?      @unique  // 👈 O CAMPO QUE FALTAVA!
  name       String
  email      String       @unique
  password   String?      // (Se no teu original estava só String, podes deixar String)
  picture    String?
  weeklyGoal Int          @default(3) // 👈 O nosso novo campo da US 33
  createdAt  DateTime     @default(now())
  
  workouts   Workout[]
  logs       WorkoutLog[]
}

// NOVO MODELO: O Treino (ex: "Dia de Peito", "Leg Day")
model Workout {
  id          String     @id @default(uuid())
  name        String     
  description String?    
  
  // Relação: Quem é o dono deste treino? 
  // O onDelete: Cascade significa que se apagares a tua conta, os teus treinos são apagados também
  userId      String     
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Relação: Um treino tem uma lista de exercícios
  exercises   Exercise[] 
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  logs        WorkoutLog[]
}

// NOVO MODELO: O Exercício dentro do treino (ex: "Supino Plano")
model Exercise {
  id          String   @id @default(uuid())
  name        String   
  sets        Int      @default(3) // Séries padrão: 3
  reps        Int      @default(10) // Repetições padrão: 10
  weight      Float?   // Peso em kg (opcional)
  
  // Relação: A que treino pertence este exercício?
  workoutId   String   
  workout     Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
}

model WorkoutLog {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) // Regista automaticamente o dia e hora
  userId    String
  workoutId String
  durationMinutes Int      @default(0)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workout   Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
}